{
  "name": "@moekoder/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs && node scripts/copy-renderer.mjs",
    "dev": "node esbuild.config.mjs && cross-env NODE_ENV=development electron .",
    "start": "pnpm build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "electron-builder",
    "package:win": "electron-builder --win --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-log": "^5.2.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "yauzl": "^3.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@moekoder/shared": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/yauzl": "^2.10.3",
    "cross-env": "^10.1.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
