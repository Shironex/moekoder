{
  "name": "@moekoder/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Moekoder — burn subtitles into video, cutely.",
  "author": {
    "name": "Shironex",
    "url": "https://github.com/Shironex/moekoder"
  },
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "node esbuild.config.mjs && node scripts/copy-renderer.mjs",
    "dev": "node esbuild.config.mjs && cross-env NODE_ENV=development electron .",
    "start": "pnpm build && electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "electron-builder",
    "package:win": "electron-builder --win --publish never",
    "package:mac": "electron-builder --mac --publish never",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "yauzl": "^3.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@moekoder/shared": "workspace:*",
    "@types/node": "^22.10.0",
    "@types/yauzl": "^2.10.3",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
