---
/**
 * Static (SSG-rendered) download CTA used on the index page.
 *
 * Pulls real asset data at build time via `loadLatestRelease()`, so the
 * homepage shows the actual latest filenames, sizes, and release date.
 * Falls back to "Open on GitHub" when the fetch fails or no asset matches
 * the electron-builder naming pattern. The /download route hosts a React
 * island that runtime-fetches from the same feed for same-day freshness.
 */
import '../styles/components/download.css';
import { loadLatestRelease } from '../lib/release';
import { formatBytes, formatDate } from '../lib/site';

const release = await loadLatestRelease();
const windowsHref = release.windows?.url ?? release.htmlUrl;
const macHref = release.mac?.url ?? release.htmlUrl;
---

<section class="download" id="download">
  <div class="bg-kanji">焼</div>
  <div class="container">
    <div class="download-inner">
      <div class="download-eyebrow">
        <span class="tag">● v{release.version}</span>
        released {formatDate(release.publishedAt)} · source available
      </div>
      <h2>Get burning. <em>It's free.</em></h2>
      <p>
        Download the installer for your OS. No account, no email, no "hi we've been trying to
        reach you about your car's extended warranty". Just a binary. Bring your own MKV and ASS.
      </p>

      <div class="platforms platforms--win">
        <a class="plat plat--primary" href={windowsHref} target="_blank" rel="noopener">
          <span class="plat-os">Windows · installer</span>
          <span class="plat-name">
            {release.windows?.name ?? 'Open on GitHub'}
          </span>
          <span class="plat-file">
            win 10 · 11 · x64{release.windows ? ` · ${formatBytes(release.windows.size)}` : ''}
          </span>
          <span class="plat-arrow">{release.windows ? '↓' : '↗'}</span>
        </a>
        <a class="plat" href={macHref} target="_blank" rel="noopener">
          <span class="plat-os">macOS · disk image</span>
          <span class="plat-name">
            {release.mac?.name ?? 'Open on GitHub'}
          </span>
          <span class="plat-file">
            mac 12+ · universal{release.mac ? ` · ${formatBytes(release.mac.size)}` : ''}
          </span>
          <span class="plat-arrow">{release.mac ? '↓' : '↗'}</span>
        </a>
      </div>
      <div class="download-note">
        <span class="k">窓</span>
        <span>
          Windows is the primary target. macOS builds ship when they stabilise. Linux builds are
          on the roadmap.
          <a href="https://github.com/Shironex/moekoder" target="_blank" rel="noopener">
            Track progress on GitHub →
          </a>
        </span>
      </div>

      <div class="download-sub">
        <a href="https://github.com/Shironex/moekoder" target="_blank" rel="noopener">
          ↗ Source on GitHub
        </a>
        <a href="/changelog">↗ Release notes</a>
        <a
          href="https://github.com/Shironex/moekoder/releases/latest"
          target="_blank"
          rel="noopener"
        >
          ↗ All releases
        </a>
      </div>
    </div>
  </div>
</section>
