---
import '../styles/components/hero.css';
---

<section class="hero">
  <div class="bg-kanji">焼</div>
  <div class="container">
    <div class="hero-meta">
      <span class="dot"></span>
      <span>v0.1 · released 2026/04</span>
      <span>·</span>
      <span><span class="num">無</span> free forever</span>
      <span>·</span>
      <span>MIT license</span>
    </div>

    <h1 class="hero-title">
      Burn subs.<br />
      <em>Quietly.</em>
      <span class="slash">—</span>
      Cutely.
    </h1>

    <p class="hero-kicker">
      MoeKoder is a <b>tiny desktop app</b> that hardsubs your MKV with its ASS — and then gets out
      of your way. GPU-accelerated, preset-driven, <b>no cloud, no account, no pop-ups</b>. The
      kettle boils; your episode is ready.
    </p>

    <div class="hero-ctas">
      <a class="btn-primary" href="/download">
        <span class="k">↓</span>
        <span class="t">
          <span>Download for Windows</span>
          <em>14 mb · win 10 &amp; 11 · free</em>
        </span>
      </a>
      <a
        class="btn-ghost"
        href="https://github.com/Shironex/moekoder"
        target="_blank"
        rel="noopener"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.4-4-1.4-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.4 1.2a11.7 11.7 0 0 1 6.2 0c2.4-1.5 3.4-1.2 3.4-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
          ></path>
        </svg>
        View source on GitHub
      </a>
    </div>

    <div class="hero-stats">
      <div class="s"><b>~14 MB</b>installer size</div>
      <div class="s"><b>GPU</b>NVENC · QSV · AMF</div>
      <div class="s"><b>Win</b>10 · 11 · x64</div>
      <div class="s"><b>0</b>trackers · telemetry</div>
      <div class="s"><b>MIT</b>open-source forever</div>
    </div>
  </div>
</section>
