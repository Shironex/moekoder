---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Moekoder — Burn subtitles into anime, cutely. A tiny, GPU-accelerated desktop hardsub tool. No cloud. No account. Source available.',
  image = '/og-default.png',
} = Astro.props;

const ogImage = new URL(image, Astro.site ?? Astro.url);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="color-scheme" content="dark" />

<title>{title}</title>
<meta name="description" content={description} />

<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

{/*
  Shippori Mincho lives on Google Fonts — a full Japanese serif subset is
  ~5 MB per weight, so self-hosting all three shipped weights would balloon
  the landing payload by ~25 MB. Google auto-subsets the response to the
  glyphs the page actually renders (a handful of kanji on headings), which
  for us is well under 50 KB total. `preconnect` warms the TLS handshake
  before the CSS import needs it. DM Sans + JetBrains Mono are self-hosted
  in `styles/fonts.css` — this link is only for Shippori Mincho.
*/}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;700;800&display=swap"
/>

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
