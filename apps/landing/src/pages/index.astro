---
const title = 'Moekoder · coming soon';
---
<!doctype html>
<html lang="en" data-theme="midnight">
<head>
  <meta charset="utf-8">
  <title>{title}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root {
      --bg: oklch(0.09 0.030 250);
      --fg: oklch(0.97 0.015 220);
      --primary: oklch(0.70 0.20 220);
    }
    html, body { margin: 0; padding: 0; height: 100%; background: var(--bg); color: var(--fg); font-family: system-ui, sans-serif; }
    body { display: grid; place-items: center; text-align: center; }
    .sigil { font-size: 180px; font-weight: 800; color: var(--primary); line-height: 0.9; text-shadow: 0 0 60px color-mix(in oklab, var(--primary) 40%, transparent); }
    .name { font-size: 36px; font-weight: 700; margin-top: 12px; }
    .kicker { font-size: 12px; letter-spacing: 0.3em; text-transform: uppercase; opacity: 0.5; margin-top: 16px; font-family: ui-monospace, monospace; }
  </style>
</head>
<body>
  <main>
    <div class="sigil">夜</div>
    <div class="name">Moekoder</div>
    <div class="kicker">coming soon · 萌コーダー</div>
  </main>
</body>
</html>
