---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import AppPreview from '../components/AppPreview.astro';
import Byo from '../components/Byo.astro';
import SectionHead from '../components/SectionHead.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import Engine from '../components/Engine.astro';
import DownloadSection from '../components/DownloadSection.astro';
import Suite from '../components/Suite.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="MoeKoder — Burn subtitles into video, cutely.">
  <Navbar />
  <Hero />
  <AppPreview />
  <Byo />

  <section class="features" id="features">
    <div class="container">
      <SectionHead n="壱" eyebrow="features · 特徴">
        Everything it does. <em>Nothing</em> it doesn't.
      </SectionHead>
      <FeatureGrid />
    </div>
  </section>

  <section class="engine" id="engine">
    <div class="container">
      <SectionHead n="弐" eyebrow="under the hood · 仕組み">
        It's <em>ffmpeg.</em> Wearing a yukata.
      </SectionHead>
      <Engine />
    </div>
  </section>

  <DownloadSection />
  <Suite />
  <Footer />
</BaseLayout>
