---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { loadChangelog } from '../lib/changelog';
import '../styles/components/changelog.css';

const { releases, intro } = await loadChangelog();
---

<BaseLayout
  title="MoeKoder · Changelog"
  description="All notable changes to MoeKoder, in reverse chronological order. Keep-a-Changelog style, MIT."
>
  <Navbar />

  <main class="changelog">
    <div class="bg-kanji">記</div>
    <div class="container">
      <div class="changelog-head">
        <div class="eyebrow">changelog · 記録</div>
        <h1>
          Every <em>change</em>, on a single page.
        </h1>
      </div>

      {
        intro.length > 0 && (
          <div class="release-intro" style="margin-bottom: 24px;">
            {intro.map((line) => (
              <p>{line}</p>
            ))}
          </div>
        )
      }

      <div class="changelog-list">
        {
          releases.map((release) => (
            <article class={`release${release.isUnreleased ? ' release--unreleased' : ''}`}>
              <header class="release-head">
                <div class="release-version">
                  {release.isUnreleased ? (
                    <em>Unreleased</em>
                  ) : (
                    <span>
                      <em>v{release.version}</em>
                    </span>
                  )}
                </div>
                {release.date && <div class="release-date">{release.date}</div>}
              </header>

              {release.intro.length > 0 && (
                <div class="release-intro">
                  {release.intro.map((line) => (
                    <p>{line}</p>
                  ))}
                </div>
              )}

              {release.sections.map((section) => (
                <section class="release-section">
                  <div class="release-section-heading">{section.heading}</div>
                  <ul class="release-entries">
                    {section.entries.map((entry) => (
                      <li>{entry}</li>
                    ))}
                  </ul>
                </section>
              ))}
            </article>
          ))
        }
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
