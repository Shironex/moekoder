{
  "name": "moekoder",
  "version": "0.0.0",
  "private": true,
  "description": "Moekoder - Burn subtitles into video, cutely.",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev": "concurrently -k -n web,desktop -c cyan,yellow \"pnpm dev:web\" \"wait-on -t 30000 -i 1000 http-get://localhost:15180 && pnpm dev:desktop\"",
    "dev:web": "pnpm --filter @moekoder/web dev",
    "dev:desktop": "pnpm --filter @moekoder/desktop dev",
    "dev:landing": "pnpm --filter @moekoder/landing dev",
    "build": "pnpm --filter @moekoder/web build && pnpm --filter @moekoder/desktop build",
    "build:landing": "pnpm --filter @moekoder/landing build",
    "package": "pnpm build && pnpm --filter @moekoder/desktop package",
    "package:win": "pnpm build && pnpm --filter @moekoder/desktop package:win",
    "package:mac": "pnpm build && pnpm --filter @moekoder/desktop package:mac",
    "generate-icons": "node scripts/generate-icons.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm --filter @moekoder/desktop test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "wait-on": "^9.0.1"
  }
}
